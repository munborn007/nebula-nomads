# NFT contract address — required for real on-chain minting (Sepolia/mainnet).
# When unset, app runs in demo mode (simulated mints, no blockchain). See MINTING.md.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Optional: RPC URL for server-side NFT lookup (Profile/Dashboard show real owned tokens).
# e.g. https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY or https://sepolia.infura.io/v3/YOUR_KEY
NEXT_PUBLIC_RPC_URL=

# Wallet for Buy 21–30 ETH payments and free-mint test wallet (same address typical).
NEXT_PUBLIC_PAYMENT_WALLET=0x8e5464173Cf64cdcdE93Aa15C41EeB8E1752E82b

# Hardhat / deploy: RPC and deployer key (for scripts/deploy.js). See DEPLOY.md.
ALCHEMY_API_KEY=
# Or: INFURA_API_KEY=
DEPLOYER_PRIVATE_KEY=
# Optional: override baseURI for deploy (default: NEXT_PUBLIC_SITE_URL + /api/metadata/)
# BASE_URI=https://nebula-nomads-ci2j.vercel.app/api/metadata/

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=

# Optional: reCAPTCHA site key for mint page
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Optional: public site URL for sitemap/robots
NEXT_PUBLIC_SITE_URL=https://nebula-nomads.vercel.app
